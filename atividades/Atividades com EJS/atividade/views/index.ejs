<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        .hero-section {
            background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
            padding: 4rem 2rem;
            border-radius: 0 0 2rem 2rem;
        }
        .card-img-top {
            object-fit: cover;
            height: 200px;
        }
        footer {
            background-color: #f8f9fa;
        }
    </style>
</head>
<body>

<section id="pagina-index" class="pb-5">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="#"><i class="bi bi-bootstrap-fill me-2"></i>BootSite</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarIndex" aria-controls="navbarIndex" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarFotos">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link active" href="index.ejs"><i class="bi bi-house-door"></i> Index</a></li>
                    <li class="nav-item"><a class="nav-link" href="contato.ejs"><i class="bi bi-envelope"></i> Contato</a></li>
                    <li class="nav-item"><a class="nav-link" href="detalhes.ejs"><i class="bi bi-info-circle"></i> Detalhes</a></li>
                    <li class="nav-item"><a class="nav-link" href="receitas.ejs"><i class="bi bi-book"></i> Receitas</a></li>
                    <li class="nav-item"><a class="nav-link" href="fotos.ejs"> <i class="bi bi-images"></i> Fotos</a> </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="hero-section text-white text-center">
        <div class="container">
            <h1 class="display-4 fw-bold">Bem-vindo ao BootSite</h1>
            <p class="lead fs-3">Site de Receitas feito com <strong>Bootstrap</strong> </p>
            <a href="receitas.html" class="btn btn-light btn-lg mt-3">Conheça nossas receitas</a>
        </div>
    </div>

    <hr class="my-5">
    <div class="container my-5">
        <div class="row row-cols-1 row-cols-md-3 g-4">
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="assets/Macarrao-a-bolonhesa.jpg" class="card-img-top" alt="Placeholder">
                    <div class="card-body">
                        <h5 class="card-title">Macarrão à Bolonhesa</h5>
                        <p class="card-text">Receita de Macarrão à Bolonhesa com...</p>
                        <a href="#" class="btn btn-outline-primary">Ver mais</a>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="assets/pudim.jpg" class="card-img-top" alt="Placeholder">
                    <div class="card-body">
                        <h5 class="card-title">Pudim de Leite</h5>
                        <p class="card-text">Receita de Pudim de Leite...</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-success">Novo</span>
                            <small class="text-muted">12 min</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-sm bg-light">
                    <div class="card-body">
                        <h5 class="card-title">Curso de Culinária</h5>
                        <p class="mb-0">A partir de:</p>
                        <p class="display-6">R$ 29,90</p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check-circle-fill text-success"></i> 1 usuário</li>
                            <li><i class="bi bi-check-circle-fill text-success"></i> Mais de 100 técnicas</li>
                            <li><i class="bi bi-check-circle-fill text-success"></i> Receitas novas todos os dias</li>
                            <li><i class="bi bi-check-circle-fill text-success"></i> Suporte 24/7</li>
                        </ul>
                        <a href="#" class="btn btn-primary w-100">Assinar</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
</body>
</html>