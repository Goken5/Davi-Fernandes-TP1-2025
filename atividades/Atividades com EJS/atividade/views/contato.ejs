<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contato</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</head>
<body>
    <section id="pagina-contato" class="bg-light">
        <nav class="navbar navbar-expand-lg navbar-dark bg-success mb-4">
            <div class="container">
                <a class="navbar-brand" href="#"><i class="bi bi-envelope-fill me-2"></i>Contato</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContato">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarFotos">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link" href="index.ejs"><i class="bi bi-house-door"></i> Index</a></li>
                        <li class="nav-item"><a class="nav-link active" href="contato.ejs"><i class="bi bi-envelope"></i> Contato</a></li>
                        <li class="nav-item"><a class="nav-link" href="detalhes.ejs"><i class="bi bi-info-circle"></i> Detalhes</a></li>
                        <li class="nav-item"><a class="nav-link" href="receitas.ejs"><i class="bi bi-book"></i> Receitas</a></li>
                        <li class="nav-item"><a class="nav-link" href="fotos.ejs"> <i class="bi bi-images"></i> Fotos</a> </li>
                    </ul>
                </div>
            </div>
        </nav>
    
        <div class="container">
            <div class="row mb-5">
                <div class="col-lg-6 mx-auto">
                    <div class="card shadow border-0">
                        <div class="card-body p-4 text-center">
                            <i class="bi bi-chat-dots-fill display-1 text-success"></i>
                            <h3 class="card-title">Fale conosco</h3>
                            <p class="card-text">Estamos disponíveis para tirar dúvidas e receber sugestões.</p>
                            <p class="card-text">Caso tenha alguma reclamação, também aceitamos envio pelo formulário</p>
                            <p><i class="bi bi-telephone-fill"></i> (22) 12345-6789</p>
                            <p> <i class="bi bi-envelope-fill"></i> email.receitas@email.com</p>
                        </div>
                    </div>
                </div>
            </div>
    
            <div class="row mb-5">
                <div class="col-md-8 mx-auto">
                    <h4 class="mb-3">Perguntas frequentes:</h4>
                    <div class="accordion" id="accordionContato">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne">
                                    Qual o horário de atendimento?
                                </button>
                            </h2>
                            <div id="collapseOne" class="accordion-collapse collapse" data-bs-parent="#accordionContato">
                                <div class="accordion-body">
                                    Atendimento de segunda a sexta, das 9h às 18h.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo">
                                    Como faço para solicitar um orçamento?
                                </button>
                            </h2>
                            <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#accordionContato">
                                <div class="accordion-body">
                                    Utilize o formulário abaixo ou envie um e-mail para contato@bootsite.com.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree">
                                    Vocês trabalham com freelancers?
                                </button>
                            </h2>
                            <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#accordionContato">
                                <div class="accordion-body">
                                    Sim, temos vagas para parceiros. Envie seu portfólio.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
    
            <!-- form (contato) -->
            <div class="row">
                <div class="col-md-8 mx-auto">
                    <div class="card p-4">
                        <h4 class="mb-3">Envie sua mensagem</h4>
                        <form action="/perguntas" method="post">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Nome</label>
                                    <input type="text" class="form-control" placeholder="Seu nome">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">E-mail</label>
                                    <input type="email" class="form-control" placeholder="email@exemplo.com">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Assunto</label>
                                    <input type="text" class="form-control" placeholder="Assunto">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Mensagem</label>
                                    <textarea class="form-control" rows="4" placeholder="Digite sua mensagem"></textarea>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-success w-100">Enviar</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <hr class="my-5">
    </section>
</body>
</html>